# Railway sets DATABASE_URL automatically when you add a Postgres plugin.
# For local dev, point it at a local Postgres instance.
DATABASE_URL=postgres://user:pass@localhost:5432/recipes

# Required for AI-assisted variant generation.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: port (Railway sets this automatically)
PORT=3000
